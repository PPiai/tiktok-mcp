# TikTok MCP Server Environment Variables
# Copy this to .env and fill in your values (optional - for official API only)

# Official TikTok API Credentials (requires developer approval)
# Get from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret
TIKTOK_ACCESS_TOKEN=your_access_token

# Note: If these are not set, the server will use public scraping as fallback