# TikTok MCP Server - Variaveis de Ambiente
# Copie para .env e preencha (credenciais sao opcionais - so para API oficial)

# ---- Servidor / Transport ----
# streamable-http (padrao, para hospedar) ou stdio (uso local)
MCP_TRANSPORT=streamable-http
HOST=0.0.0.0
PORT=8000

# ---- Credenciais TikTok API Oficial (requer aprovacao de desenvolvedor) ----
# Obtenha em: https://developers.tiktok.com/
# Se nao definidas, o servidor usa scraping publico como fallback.
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret
TIKTOK_ACCESS_TOKEN=your_access_token
